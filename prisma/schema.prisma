model LigneBonSortieTransfert {
  id          String             @id @default(cuid())
  bonId       String
  bon         BonSortieTransfert @relation(fields: [bonId], references: [id], onDelete: Cascade)
  materielId  String
  materiel    Materiel           @relation(fields: [materielId], references: [id])
  quantite    Int
  etat        String?
  observation String?
}

// ─────────────────────────────────────────────────────────────────────────
// Lot 7 — Service Achat. Le circuit le plus complexe du projet : l'étape de
// validation standard est PARALLÈLE (le Responsable Achat sélectionne
// dynamiquement un sous-ensemble de DT/RH/DFC/DG qui doivent TOUS valider ;
// un seul refus bloque tout), contrairement à tous les circuits précédents
// (séquentiels, un validateur/rôle à la fois). DemandeIndex ne représentant
// nativement qu'UNE cible de routage à la fois, ValidationDemandeAchat est
// une table de suivi dédiée au grain "rôle" (même principe que
// LigneDemandeRHProjet au grain "ligne", Lot 5) — cf. CLAUDE.md pour le
// raisonnement complet, y compris le sentinel enAttenteValidationDe et la
// mécanique d'unicité partielle de BonDeCommande.
// ─────────────────────────────────────────────────────────────────────────

enum ForTypeDemandeAchat {
  SERVICE
  CHANTIER
}

/// Classification pure pour ce lot — aucune branche du circuit ne dépend de
/// cette valeur (choix de scope minimal délibéré, cf. CLAUDE.md).
enum TypeDemandeAchat {
  INITIALE
  REGULARISATION
}

enum StatutDemandeAchat {
  EN_ATTENTE_DIRECTEUR
  EN_ATTENTE_TRAITEMENT_ACHAT
  EN_ATTENTE_VALIDATION_PARALLELE
  REFUSEE
  BC_EMIS
}

/// Détermine où reprend le circuit après un refus et resoumission — cf.
/// CLAUDE.md (un refus Directeur renvoie à l'étape 2, rien à refaire côté
/// Achat ; un refus d'un validateur parallèle renvoie à l'étape 3, les
/// termes fixés par Achat sont ce qui a pu changer).
enum EtapeBlocageDemandeAchat {
  DIRECTEUR
  VALIDATION_PARALLELE
}

enum TypePaiementAchat {
  CHEQUE
  VIREMENT
  ESPECES
  MOBILE_MONEY
}

enum ModeTarificationLigneAchat {
  FORFAITAIRE
  CALCULE
}

enum RoleValidationAchat {
  DT
  RH
  DFC
  DG
}

enum StatutValidationDemandeAchat {
  EN_ATTENTE
  VALIDEE
  REFUSEE
}

enum StatutBonDeCommande {
  OUVERT
  ENVOYE
}

/// Circuit : 1) demandeur sélectionne des Article (désignation seule, prix
/// masqué côté serveur) ou saisit une désignation libre ; 2) validation du
/// Directeur du département (directeurDepartementId, figé depuis
/// demandeur.superieurId — même pattern que DemandeAbsence, Lot 4) ; 3) le
/// Responsable Achat traite (prix/fournisseur/devis/termes de paiement,
/// urgent ou sélection de validateurs) ; 4) validation parallèle
/// (ValidationDemandeAchat) si non urgent ; 5) Bon de Commande émis, groupé
/// par fournisseur (BonDeCommande) ; 6) réception via BonEntreeMagasin (Lot
/// 6, lien bonDeCommandeId) ; 7) facturation/paiement — Lot 8 (DFC), hors
/// scope, BC_EMIS est un état terminal pour ce lot côté DemandeIndex. Cf.
/// CLAUDE.md.
model DemandeAchat {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  forType              ForTypeDemandeAchat
  /// Code Module libre (ex: "rh", "logistique") si forType=SERVICE — jamais
  /// une FK, même convention que DemandeIndex.typeModule. Cf. CLAUDE.md.
  forServiceModuleCode String?
  projetId             String?
  projet               Projet?             @relation("DemandeAchatChantier", fields: [projetId], references: [id])
  chantierLibre        String?

  /// Dimension séparée de forType/for*Id ci-dessus : le lieu de LIVRAISON
  /// physique peut différer de l'entité pour laquelle la demande est faite
  /// (ex: demande POUR le service RH, livrée SUR un chantier). Même paire
  /// FK-nullable+texte-libre que DemandeMateriel (Lot 5).
  lieuLivraisonProjetId  String?
  lieuLivraisonProjet    Projet?  @relation("DemandeAchatLieuLivraison", fields: [lieuLivraisonProjetId], references: [id])
  lieuLivraisonLibre     String?
  dateLivraisonSouhaitee DateTime

  type TypeDemandeAchat @default(INITIALE)

  /// Trois acteurs distincts, jamais fusionnés : demandeurId (bénéficiaire
  /// réel, pilote directeurDepartementId), emetteurId (porteur/responsable
  /// budgétaire, souvent = demandeurId), creeParId (qui a rempli le
  /// formulaire, peut différer des deux). Cf. CLAUDE.md.
  demandeurId String
  demandeur   Utilisateur @relation("UtilisateurDemandeurAchat", fields: [demandeurId], references: [id])
  emetteurId  String
  emetteur    Utilisateur @relation("UtilisateurEmetteurAchat", fields: [emetteurId], references: [id])
  creeParId   String
  creePar     Utilisateur @relation("UtilisateurCreateurAchat", fields: [creeParId], references: [id])

  justification String

  statut       StatutDemandeAchat        @default(EN_ATTENTE_DIRECTEUR)
  motifRefus   String?
  etapeBlocage EtapeBlocageDemandeAchat?

  /// Figé depuis demandeur.superieurId à la création — même pattern que
  /// DemandeAbsence.superieurId (Lot 4). Re-figé à chaque resoumission après
  /// un refus du Directeur (le supérieur a pu changer entretemps).
  directeurDepartementId  String
  directeurDepartement    Utilisateur @relation("UtilisateurDirecteurAchat", fields: [directeurDepartementId], references: [id])
  dateValidationDirecteur DateTime?

  // Étape 3 — traitement Responsable Achat
  traiteParId           String?
  traitePar             Utilisateur?       @relation("UtilisateurTraitantAchat", fields: [traiteParId], references: [id])
  dateTraitement        DateTime?
  dateLivraisonPrevue   DateTime?
  tauxTva               Decimal?           @db.Decimal(5, 2)
  typePaiement          TypePaiementAchat?
  /// 30 ou 60 jours.
  echeancePaiementJours Int?
  montantTotalTTC       Decimal?           @db.Decimal(14, 2)
  urgent                Boolean            @default(false)
  /// ParametresAchat.seuilUrgence figé au moment de la décision "urgent" —
  /// jamais recalculé ensuite, même principe d'audit-freeze que
  /// DemandeCarburant.cumulMensuelAvant (Lot 3).
  seuilUrgenceApplique  Decimal?           @db.Decimal(14, 2)

  lignes             LigneDemandeAchat[]
  validations        ValidationDemandeAchat[]
  piecesJointesDevis PieceJointeDevis[]

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([statut])
  @@index([demandeurId])
  @@index([directeurDepartementId, statut])
}

model LigneDemandeAchat {
  id        String       @id @default(cuid())
  demandeId String
  demande   DemandeAchat @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  /// Choix référencé (Bordereau/Article, désignation seule visible au
  /// demandeur) OU saisie libre non référencée — jamais les deux.
  articleId        String?
  article          Article? @relation(fields: [articleId], references: [id])
  designationLibre String?
  quantite         Int

  // Renseigné par le Responsable Achat à l'étape 3 — jamais visible au
  // demandeur avant traitement.
  fournisseur        String?
  modeTarification   ModeTarificationLigneAchat?
  prixUnitaire       Decimal?                    @db.Decimal(14, 2)
  montantForfaitaire Decimal?                    @db.Decimal(14, 2)
  /// = montantForfaitaire OU prixUnitaire*quantite, stocké — jamais recalculé
  /// à la lecture.
  montantLigneHT     Decimal?                    @db.Decimal(14, 2)

  ligneBC LigneBonDeCommande?

  @@index([demandeId])
  @@index([articleId])
}

/// Table dédiée au grain "rôle sélectionné", jamais "personne nommée" — cf.
/// décision confirmée : diffusion par rôle, comme tous les autres circuits
/// de diffusion de ce projet (DG, RH). Une ligne par rôle choisi par le
/// Responsable Achat pour CETTE demande (sous-ensemble de DT/RH/DFC/DG) ;
/// le premier utilisateur habilité pour ce rôle qui agit remporte le
/// créneau (garde atomique via updateMany, même idiome que les décréments
/// de stock). @@unique([demandeId, role]) empêche un doublon de rôle. Cf.
/// CLAUDE.md pour recalculerStatutDemandeAchat() et la remise à zéro
/// complète en cas de resoumission après refus.
model ValidationDemandeAchat {
  id          String                       @id @default(cuid())
  demandeId   String
  demande     DemandeAchat                 @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  role        RoleValidationAchat
  statut      StatutValidationDemandeAchat @default(EN_ATTENTE)
  motifRefus  String?
  valideParId String?
  validePar   Utilisateur?                 @relation(fields: [valideParId], references: [id])
  dateAction  DateTime?

  @@unique([demandeId, role])
  @@index([demandeId])
  @@index([role, statut])
}

/// "Un BC ouvert par fournisseur à la fois", résolu sans index partiel SQL
/// manuel : ouvertMarqueur ne vaut true que tant que statut=OUVERT, remis à
/// null (jamais false) dès "Envoyé". Postgres traitant NULL comme toujours
/// distinct dans une contrainte unique — le même fait dont
/// DemandeIndex.enAttenteValidationDe/UtilisateurId dépend déjà pour son
/// propre signal binaire — @@unique([fournisseur, ouvertMarqueur]) n'exclut
/// donc que les doublons OUVERT pour un même fournisseur ; un nombre
/// illimité de BC ENVOYE peut coexister pour le même fournisseur. Cf.
/// CLAUDE.md.
model BonDeCommande {
  id          String              @id @default(cuid())
  numero      Int                 @unique @default(autoincrement())
  fournisseur String
  statut      StatutBonDeCommande @default(OUVERT)

  /// Lot 8 (DFC) : lien auto-établi par trouverOuCreerBonDeCommandeOuvert()
  /// (achat-bons-commande.ts) vers un Fournisseur référencé — champ
  /// purement additif, jamais utilisé pour le groupement (qui reste basé
  /// sur la chaîne `fournisseur` ci-dessus, inchangée). Nommé `fournisseurRef`
  /// plutôt que `fournisseur` pour ne jamais confondre les deux champs à la
  /// lecture. Cf. CLAUDE.md.
  fournisseurId  String?
  fournisseurRef Fournisseur? @relation(fields: [fournisseurId], references: [id])

  ouvertMarqueur Boolean?

  envoyeParId String?
  envoyePar   Utilisateur? @relation(fields: [envoyeParId], references: [id])
  dateEnvoi   DateTime?

  lignes            LigneBonDeCommande[]
  bonsEntreeMagasin BonEntreeMagasin[]

  dateCreation DateTime @default(now())
  facture      Facture?

  @@unique([fournisseur, ouvertMarqueur])
  @@index([statut])
}

model LigneBonDeCommande {
  id                  String            @id @default(cuid())
  bonDeCommandeId     String
  bonDeCommande       BonDeCommande     @relation(fields: [bonDeCommandeId], references: [id], onDelete: Cascade)
  ligneDemandeAchatId String            @unique
  ligneDemandeAchat   LigneDemandeAchat @relation(fields: [ligneDemandeAchatId], references: [id])
  quantite            Int
  prixUnitaire        Decimal           @db.Decimal(14, 2)
  montantLigneTTC     Decimal           @db.Decimal(14, 2)

  @@index([bonDeCommandeId])
}

/// Réutilise le bucket Storage privé "documents" du Lot 2 (préfixe
/// "achat/devis/"), même pattern que PieceJointeAppelOffres (Lot 5) — pas de
/// nouvelle infrastructure. Cf. CLAUDE.md.
model PieceJointeDevis {
  id                 String       @id @default(cuid())
  demandeId          String
  demande            DemandeAchat @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  cheminFichier      String
  nomFichierOriginal String

  ajouteParId String?
  ajoutePar   Utilisateur? @relation(fields: [ajouteParId], references: [id])

  dateAjout DateTime @default(now())
}

/// Référentiel de configuration à une seule ligne — même philosophie "table
/// plutôt qu'enum" que CategorieMateriel/UniteMesure, corrigeable via
/// pnpm db:seed sans migration. obtenirParametresAchat() fait un
/// findFirst() ?? create() défensif même si le seed crée toujours une ligne.
model ParametresAchat {
  id           String  @id @default(cuid())
  seuilUrgence Decimal @db.Decimal(14, 2)

  modifieParId     String?
  modifiePar       Utilisateur? @relation(fields: [modifieParId], references: [id])
  dateModification DateTime     @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────
// Lot 8 — DFC / Finances et Comptabilité. Referme deux dépendances
// laissées volontairement terminales par des lots antérieurs :
// DemandeMission (Lot 4, VALIDEE_RH + fraisDeclares en attente de
// paiement) et BonDeCommande (Lot 7, BC_EMIS en attente de
// facturation/paiement). Introduit un circuit de paiement urgent Wave —
// SIMULÉ, aucune vraie clé API n'existe dans ce projet, cf.
// appellerApiWaveSimulee() (lib/paiement-urgent-wave.ts) et la mise en
// garde dédiée dans CLAUDE.md. Cf. CLAUDE.md pour le raisonnement complet.
// ─────────────────────────────────────────────────────────────────────────

enum StatutCodeAutorisationPaiementUrgent {
  EN_ATTENTE_DG
  VALIDE
  REFUSE
  UTILISE
  /// Valeur cosmétique seulement — jamais posée par un job planifié (aucune
  /// infra cron dans ce projet). demanderCodeAutorisation() la pose de
  /// façon opportuniste sur un ancien code VALIDE-mais-expiré au moment où
  /// elle retombe dessus (vérification anti-doublon) — un confort de
  /// lecture, jamais requis pour la correction : tout chemin de
  /// lecture/consommation revérifie dateExpiration > now() indépendamment
  /// de ce champ. Cf. CLAUDE.md.
  EXPIRE
}

/// Référentiel fournisseur — lié en toile de fond par
/// trouverOuCreerBonDeCommandeOuvert() (achat-bons-commande.ts), jamais
/// saisi directement par le Responsable Achat (qui continue de taper un
/// nom libre sur LigneDemandeAchat/BonDeCommande.fournisseur, inchangé).
/// nom est la clé naturelle unique (pas de code court comme Magasin — les
/// fournisseurs n'en ont pas dans ce projet). Cf. CLAUDE.md.
model Fournisseur {
  id         String  @id @default(cuid())
  nom        String  @unique
  numeroWave String?
  actif      Boolean @default(true)

  bonsDeCommande   BonDeCommande[]
  paiementsUrgents PaiementUrgent[] @relation("FournisseurBeneficiairePaiementUrgent")

  dateCreation DateTime @default(now())
}

/// Facture reçue d'un fournisseur, liée à un BonDeCommande — scope
/// volontairement minimal, un BC = une Facture (bonDeCommandeId unique).
/// Si un besoin de facturation partielle/multiple par BC apparaît dans un
/// lot futur, ce @unique est le premier endroit à revisiter. Cf. CLAUDE.md.
model Facture {
  id              String        @id @default(cuid())
  bonDeCommandeId String        @unique
  bonDeCommande   BonDeCommande @relation(fields: [bonDeCommandeId], references: [id])

  referenceFournisseur String
  montant              Decimal  @db.Decimal(14, 2)
  dateFacture          DateTime

  enregistreParId String?
  enregistrePar   Utilisateur? @relation("UtilisateurEnregistreFacture", fields: [enregistreParId], references: [id])

  dateEnregistrement DateTime @default(now())

  paiement Paiement?

  @@index([bonDeCommandeId])
}

/// Exécution réelle d'un paiement (circuit standard) — exactement UN des
/// deux liens (factureId/demandeMissionId), jamais les deux, jamais aucun :
/// appliqué en code, pas en contrainte DB, même idiome que
/// DemandeMateriel.projetId?/chantierLibre? — pas le pattern polymorphe
/// entiteType+entiteId (réservé aux tables génériques HistoriqueStatut/
/// DemandeIndex/Notification), deux vraies relations Prisma distinctes ici
/// car exactement deux parents possibles, connus à l'avance. Pas de champ
/// statut : la création EST le paiement (DFC "exécute" en une seule étape
/// — le BC/la Mission ont déjà traversé leur propre circuit de validation
/// complet, rien à revalider ici). Cf. CLAUDE.md.
model Paiement {
  id String @id @default(cuid())

  factureId String?  @unique
  facture   Facture? @relation(fields: [factureId], references: [id])

  demandeMissionId String?         @unique
  demandeMission   DemandeMission? @relation(fields: [demandeMissionId], references: [id])

  montant       Decimal           @db.Decimal(14, 2)
  /// Réutilise TypePaiementAchat (Lot 7) tel quel — déjà générique,
  /// dupliquer un enum identique serait un pur doublon.
  mode          TypePaiementAchat
  reference     String?
  dateExecution DateTime          @default(now())

  executeParId String?
  executePar   Utilisateur? @relation("UtilisateurExecuteParPaiement", fields: [executeParId], references: [id])

  @@index([factureId])
  @@index([demandeMissionId])
}

/// Étapes 1-3 du circuit Wave urgent : demande de code par DFC, diffusion
/// "broadcast" DG (même forme que DemandeAppelOffres —
/// EN_ATTENTE_DG/VALIDE/REFUSE), consommation exactement unique à
/// l'étape 5 (PaiementUrgent). Le code n'est généré qu'à la validation
/// (jamais à la demande) — cf. randomInt() dans mot-de-passe-temporaire.ts
/// pour le précédent direct. Validité 24h vérifiée à la lecture/
/// consommation, jamais par un job planifié (aucune infra cron dans ce
/// projet). Cf. CLAUDE.md.
model CodeAutorisationPaiementUrgent {
  id String @id @default(cuid())

  demandeurId   String
  demandeur     Utilisateur @relation("UtilisateurDemandeurCodeUrgent", fields: [demandeurId], references: [id])
  justification String

  statut     StatutCodeAutorisationPaiementUrgent @default(EN_ATTENTE_DG)
  motifRefus String?

  /// Généré (6 chiffres) seulement au moment de validerCodeAutorisation() —
  /// null tant que statut=EN_ATTENTE_DG.
  code           String?
  valideParId    String?
  validePar      Utilisateur? @relation("UtilisateurValideurCodeUrgent", fields: [valideParId], references: [id])
  dateValidation DateTime?
  dateExpiration DateTime?

  dateUtilisation DateTime?

  paiementUrgent PaiementUrgent?

  dateCreation DateTime @default(now())

  @@index([demandeurId])
  @@index([statut])
}

/// Étape 5 — entièrement autonome, hors circuit standard : aucun lien vers
/// Facture/DemandeMission (décision confirmée). referenceSimulee est nommé
/// pour ne JAMAIS être confondu avec une vraie référence de transaction —
/// cf. appellerApiWaveSimulee() (lib/paiement-urgent-wave.ts) et la
/// section sécurité dédiée dans CLAUDE.md. Pas de champ statut : la ligne
/// existe seulement une fois exécutée (même raisonnement que Paiement
/// ci-dessus) — aucune action d'édition/annulation n'a de sens sur une
/// ligne créée ici, conformément à l'irréversibilité du circuit.
model PaiementUrgent {
  id String @id @default(cuid())

  codeAutorisationId String                         @unique
  codeAutorisation   CodeAutorisationPaiementUrgent @relation(fields: [codeAutorisationId], references: [id])

  // Bénéficiaire : exactement l'un des deux, appliqué en code (même idiome
  // "somme de type via deux FK nullables" que Paiement ci-dessus).
  beneficiaireUtilisateurId String?
  beneficiaireUtilisateur   Utilisateur? @relation("UtilisateurBeneficiairePaiementUrgent", fields: [beneficiaireUtilisateurId], references: [id])
  beneficiaireFournisseurId String?
  beneficiaireFournisseur   Fournisseur? @relation("FournisseurBeneficiairePaiementUrgent", fields: [beneficiaireFournisseurId], references: [id])

  montant Decimal @db.Decimal(14, 2)

  executeParId String
  executePar   Utilisateur @relation("UtilisateurExecuteurPaiementUrgent", fields: [executeParId], references: [id])

  referenceSimulee String
  dateExecution    DateTime @default(now())

  @@index([beneficiaireUtilisateurId])
  @@index([beneficiaireFournisseurId])
}
