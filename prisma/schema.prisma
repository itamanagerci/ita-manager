// Lot 0 — Socle technique : authentification, rôles, accès, pattern statut/historique.
// Aucun module métier (Achat, QHSE, etc.) n'est modélisé ici — uniquement le référentiel
// de structure (Module/SousModule) et les tables transversales.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — utilisé à l'exécution
  directUrl = env("DIRECT_URL") // connexion directe — utilisée par les migrations
}

enum NiveauHierarchique {
  DIRECTEUR
  CHEF_SERVICE
  AGENT
}

enum StatutUtilisateur {
  ACTIF
  INACTIF
}

/// Référentiel des 9 modules métier + le module transversal "0. Authentification et Rôles".
/// Contient uniquement la structure (noms/slugs) — pas les formulaires/circuits métier.
model Module {
  id          String       @id @default(cuid())
  code        String       @unique
  nom         String
  icone       String?
  ordre       Int          @default(0)
  visibleMenu Boolean      @default(true)
  sousModules SousModule[]
}

/// Chaque Module a toujours au moins un SousModule (y compris les modules "uniques"
/// comme Service Achat, via un sous-module synthétique) — évite les pièges de contrainte
/// d'unicité sur colonnes nullables et uniformise la logique de rendu/garde.
model SousModule {
  id                String                 @id @default(cuid())
  moduleId          String
  module            Module                 @relation(fields: [moduleId], references: [id])
  code              String
  nom               String
  ordre             Int                    @default(0)
  actif             Boolean                @default(true)
  fonctionDefauts   FonctionModuleDefaut[]
  accesUtilisateurs AccesUtilisateur[]

  @@unique([moduleId, code])
}

/// Référentiel des Fonctions (ex: Assistante de direction, Resp. Achat, Chef de chantier...).
/// Détermine les modules/sous-modules accessibles par défaut.
model Fonction {
  id             String                 @id @default(cuid())
  nom            String                 @unique
  description    String?
  actif          Boolean                @default(true)
  utilisateurs   Utilisateur[]
  modulesDefauts FonctionModuleDefaut[]
}

model FonctionModuleDefaut {
  id              String     @id @default(cuid())
  fonctionId      String
  fonction        Fonction   @relation(fields: [fonctionId], references: [id], onDelete: Cascade)
  sousModuleId    String
  sousModule      SousModule @relation(fields: [sousModuleId], references: [id])
  activeParDefaut Boolean    @default(true)

  @@unique([fonctionId, sousModuleId])
}

model Utilisateur {
  id                 String             @id @default(cuid())
  /// UUID Supabase Auth (auth.users.id) — comparaison par valeur uniquement.
  /// Pas de relation Prisma ni de FK gérée par migrate : le schéma auth de
  /// Supabase (sessions, MFA, OAuth...) reste entièrement hors du contrôle
  /// de Prisma pour éviter les faux drifts sur les migrations.
  authUserId         String             @unique @db.Uuid
  nom                String
  prenom             String
  email              String             @unique
  telephone          String?
  niveauHierarchique NiveauHierarchique
  fonctionId         String
  fonction           Fonction           @relation(fields: [fonctionId], references: [id])
  statut             StatutUtilisateur  @default(ACTIF)
  premiereConnexion  Boolean            @default(true)
  dateCreation       DateTime           @default(now())
  dateModification   DateTime           @updatedAt

  /// Nullable : les comptes du seed initial n'ont pas de créateur humain.
  /// Pas de onDelete Cascade — supprimer un utilisateur qui a lui-même créé
  /// d'autres comptes est bloqué par possedeDonneesLiees() (gestion-comptes.ts),
  /// même logique que les autres FK non-cascadantes vers Utilisateur.
  creeParId    String?
  creePar      Utilisateur?  @relation("UtilisateurCreateur", fields: [creeParId], references: [id])
  comptesCrees Utilisateur[] @relation("UtilisateurCreateur")

  acces             AccesUtilisateur[] @relation("AccesDuUtilisateur")
  accesModifies     AccesUtilisateur[] @relation("AccesModifiePar")
  actionsHistorique HistoriqueStatut[]

  demandesIndexSoumises DemandeIndex[] @relation("DemandeIndexDemandeur")
  demandesIndexAValider DemandeIndex[] @relation("DemandeIndexValidateur")

  documentsAjoutes Document[] @relation("UtilisateurAjouteDocument")

  demandesCarburantSoumises     DemandeCarburant[]     @relation("UtilisateurDemandeCarburant")
  reapprovisionnementsEffectues Reapprovisionnement[]  @relation("UtilisateurReapprovisionnement")

  /// Modèle minimal (un seul niveau, pas d'organigramme complet) — cf.
  /// CLAUDE.md. Pas de onDelete Cascade — supprimer un supérieur désigné
  /// est bloqué par possedeDonneesLiees(), même logique que creeParId.
  superieurId String?
  superieur   Utilisateur?  @relation("UtilisateurSuperieur", fields: [superieurId], references: [id])
  subordonnes Utilisateur[] @relation("UtilisateurSuperieur")

  profilEmploye ProfilEmploye?

  demandesAbsenceSoumises DemandeAbsence[] @relation("UtilisateurDemandeAbsence")
  demandesAbsenceAValider DemandeAbsence[] @relation("UtilisateurValidationAbsence")

  missionsConcernees DemandeMission[] @relation("UtilisateurMissionConcernee")
  missionsInitiees   DemandeMission[] @relation("UtilisateurMissionInitiee")

  relevesActivite ReleveActivite[] @relation("UtilisateurReleveOuvrier")
  relevesSaisis   ReleveActivite[] @relation("UtilisateurReleveSaisiPar")

  appelsOffresInities DemandeAppelOffres[]

  projetsDiriges      Projet[]           @relation("ProjetChefDeProjet")
  pointsValidationCoches PointValidation[]
  notifications       Notification[]

  demandesRHProjetInitiees DemandeRHProjet[]
  lignesContreProposeesPour LigneDemandeRHProjet[] @relation("LigneOuvrierContrePropose")
  affectationsProjet      AffectationProjet[]      @relation("UtilisateurAffectationOuvrier")

  demandesMaterielInitiees DemandeMateriel[]
  articlesCrees            Article[]
}

/// Droits d'accès individuels. Initialisés depuis FonctionModuleDefaut à la création
/// de l'utilisateur ; estException=true marque une exception manuelle RH, exclue de la
/// propagation automatique lors d'une évolution des defaults de la Fonction.
model AccesUtilisateur {
  id               String       @id @default(cuid())
  utilisateurId    String
  utilisateur      Utilisateur  @relation("AccesDuUtilisateur", fields: [utilisateurId], references: [id], onDelete: Cascade)
  sousModuleId     String
  sousModule       SousModule   @relation(fields: [sousModuleId], references: [id])
  actif            Boolean
  estException     Boolean      @default(false)
  modifieParId     String?
  modifiePar       Utilisateur? @relation("AccesModifiePar", fields: [modifieParId], references: [id])
  dateModification DateTime     @updatedAt

  @@unique([utilisateurId, sousModuleId])
}

/// Pattern générique réutilisé par tous les futurs circuits de validation (Achat, Congés,
/// AST...). Discriminant applicatif (entiteType, entiteId) plutôt qu'une relation
/// polymorphe (non supportée par Prisma) — aucune FK vers les tables métier futures.
model HistoriqueStatut {
  id              String      @id @default(cuid())
  entiteType      String
  entiteId        String
  statutPrecedent String?
  statutNouveau   String
  commentaire     String?
  acteurId        String
  acteur          Utilisateur @relation(fields: [acteurId], references: [id])
  dateAction      DateTime    @default(now())

  @@index([entiteType, entiteId])
}

/// Projection d'état courant ("read model") des demandes de n'importe quel
/// module métier futur, agrégée pour la Direction Générale. Complémentaire
/// à HistoriqueStatut (log d'événements immuable) : DemandeIndex ne garde
/// qu'une ligne par entité métier (upsert sur entiteType+entiteId) et
/// reflète toujours le dernier statut connu. Un futur module appelle
/// typiquement les deux à chaque transition : enregistrerTransition() pour
/// l'historique, upsertDemandeIndex() pour la projection DG.
model DemandeIndex {
  id         String  @id @default(cuid())
  typeModule String // code Module d'origine (ex: "achat") — string libre, pas de FK
  sousModule String // code SousModule d'origine — string libre, pas de FK
  reference  String? // identifiant lisible (ex: ACH-2026-00042) — numérotation hors scope

  entiteType String // même discriminant applicatif que HistoriqueStatut
  entiteId   String // @@unique permet l'upsert idempotent à chaque transition

  demandeurId String
  demandeur   Utilisateur @relation("DemandeIndexDemandeur", fields: [demandeurId], references: [id])

  statutLibelle String // libre — chaque module garde son propre enum de statut
  montant       Decimal? @db.Decimal(14, 2)

  /// Convention : une demande est "en attente" si l'un des deux champs
  /// suivants est non-null, "traitée" si les deux sont null.
  /// upsertDemandeIndex() écrase toujours les deux avec la valeur fournie
  /// (jamais de fusion partielle), pour qu'une demande résolue ne reste
  /// jamais affichée comme en attente d'un ancien validateur.
  enAttenteValidationDe            NiveauHierarchique?
  enAttenteValidationUtilisateurId String?
  enAttenteValidationUtilisateur   Utilisateur?        @relation("DemandeIndexValidateur", fields: [enAttenteValidationUtilisateurId], references: [id])

  lienDetail String? // route exacte vers le détail dans le module d'origine, fournie plus tard

  dateSoumission DateTime // date métier réelle, fournie par l'appelant
  dateMaj        DateTime @updatedAt

  @@unique([entiteType, entiteId])
  @@index([typeModule])
  @@index([enAttenteValidationUtilisateurId])
  @@index([enAttenteValidationDe])
  @@index([dateSoumission])
}

enum CategorieDocument {
  CONTRATS
  RH
  JURIDIQUE
  FACTURES
  QHSE
  ACHAT
  TECHNIQUE
  AUTRE
}

/// Lot 2 — Assistant de Direction / Archivage documentaire. Le fichier vit dans le
/// bucket Storage privé "documents" (jamais public — cf. CLAUDE.md) ; cheminFichier
/// est la clé d'objet interne (UUID, pas le nom original), nomFichierOriginal sert
/// uniquement à l'affichage/au téléchargement.
model Document {
  id                 String            @id @default(cuid())
  titre              String
  cheminFichier      String
  nomFichierOriginal String
  categorie          CategorieDocument
  dateAjout          DateTime          @default(now())

  /// Même pattern que Utilisateur.creeParId (Lot 1) : nullable, pas de onDelete
  /// Cascade — supprimer un utilisateur ayant archivé des documents est bloqué
  /// par possedeDonneesLiees() (gestion-comptes.ts).
  ajouteParId String?
  ajoutePar   Utilisateur? @relation("UtilisateurAjouteDocument", fields: [ajouteParId], references: [id])

  @@index([categorie])
}

enum StatutDemandeCarburant {
  EN_ATTENTE_LOGISTIQUE
  EN_ATTENTE_DG
  VALIDEE
  REFUSEE
}

enum TypeVehicule {
  LEGER
  LOURD
}

/// Lot 3 — Gestion Carburant. Référentiel véhicule volontairement minimal :
/// le futur Lot 6 (Logistique) l'étendra (affectation, historique, statuts...)
/// plutôt que de le remplacer — cf. CLAUDE.md.
model Vehicule {
  id                 String             @id @default(cuid())
  immatriculation    String             @unique
  type               TypeVehicule
  quotaMensuelLitres Int
  demandesCarburant  DemandeCarburant[]
}

model Depot {
  id                   String                 @id @default(cuid())
  nom                  String
  localisation         String
  chantiersRattaches   String[]
  /// Mis à jour par les mouvements (réapprovisionnement, validation finale
  /// d'une demande) — jamais recalculé à la volée à la lecture.
  quantiteStockLitres  Int                    @default(0)
  demandesCarburant    DemandeCarburant[]
  reapprovisionnements Reapprovisionnement[]
}

/// Pas de circuit de validation — saisie directe par le Responsable
/// Logistique/Carburant, incrémente Depot.quantiteStockLitres à la création.
model Reapprovisionnement {
  id             String       @id @default(cuid())
  depotId        String
  depot          Depot        @relation(fields: [depotId], references: [id])
  quantiteLitres Int
  date           DateTime     @default(now())
  fournisseur    String

  /// Même pattern non-cascadant que Utilisateur.creeParId/Document.ajouteParId.
  effectueParId String?
  effectuePar   Utilisateur? @relation("UtilisateurReapprovisionnement", fields: [effectueParId], references: [id])
}

model DemandeCarburant {
  id                     String                 @id @default(cuid())
  vehiculeId             String
  vehicule               Vehicule               @relation(fields: [vehiculeId], references: [id])
  depotSourceId          String
  depotSource            Depot                  @relation(fields: [depotSourceId], references: [id])
  kilometrageCompteur    Int
  quantiteDemandeeLitres Int
  chantierMission        String
  demandeurId            String
  demandeur              Utilisateur            @relation("UtilisateurDemandeCarburant", fields: [demandeurId], references: [id])
  statut                 StatutDemandeCarburant @default(EN_ATTENTE_LOGISTIQUE)
  motifRefus             String?

  /// Cumul mensuel du véhicule AVANT cette demande, figé à la création (sert
  /// à déterminer le hors-quota) — jamais recalculé ensuite. Cf. CLAUDE.md.
  cumulMensuelAvant Int

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([vehiculeId, statut])
  @@index([statut])
  @@index([demandeurId])
}

enum TypeProfilEmploye {
  AGENT
  SOUS_TRAITANT
  OUVRIER
}

/// Lot 4 — DARH. Relation 1:1 OPTIONNELLE avec Utilisateur (onDelete: Cascade
/// — appartient entièrement au compte, même logique que AccesUtilisateur,
/// pas un enregistrement d'audit sur l'action de quelqu'un d'autre) : un
/// compte peut exister sans profil RH complété.
model ProfilEmploye {
  id            String            @id @default(cuid())
  utilisateurId String            @unique
  utilisateur   Utilisateur       @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  typeProfil    TypeProfilEmploye
  poste         String
  service       String
  dateEntree    DateTime
  soldeConges   Int               @default(0)

  salaireFixe         Decimal? @db.Decimal(14, 2)
  entrepriseRattachee String?
  tauxJournalier      Decimal? @db.Decimal(14, 2)
}

enum TypeAbsence {
  CONGE
  PERMISSION
}

enum StatutAbsence {
  EN_ATTENTE_SUPERIEUR
  VALIDEE
  REFUSEE
}

model DemandeAbsence {
  id                 String        @id @default(cuid())
  employeId          String
  employe            Utilisateur   @relation("UtilisateurDemandeAbsence", fields: [employeId], references: [id])
  type               TypeAbsence
  dateDebut          DateTime
  dateFin            DateTime? // requis si CONGE
  dureeHeures        Int? // requis si PERMISSION
  motif              String
  statut             StatutAbsence @default(EN_ATTENTE_SUPERIEUR)
  motifRefus         String?
  impacteSoldeConges Boolean // dérivé du type à la création, jamais un input utilisateur

  /// Figé depuis employe.superieurId à la création — routage stable même si
  /// le supérieur de l'employé change ensuite. Cf. CLAUDE.md.
  superieurId String
  superieur   Utilisateur @relation("UtilisateurValidationAbsence", fields: [superieurId], references: [id])

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([employeId])
  @@index([superieurId, statut])
}

enum TypeMission {
  CHANTIER
  FORMATION
  REPRESENTATION_CLIENT
  AUTRE
}

enum StatutMission {
  EN_ATTENTE_RH
  VALIDEE_RH
  REFUSEE
}

/// Se termine à VALIDEE_RH pour ce lot — le futur Lot 8 (DFC) reprendra les
/// missions à ce statut pour l'étape de paiement. Cf. CLAUDE.md.
model DemandeMission {
  id                String      @id @default(cuid())
  employeConcerneId String
  employeConcerne   Utilisateur @relation("UtilisateurMissionConcernee", fields: [employeConcerneId], references: [id])

  /// Peut différer de employeConcerneId (un supérieur soumet pour son équipe).
  initiateurId String
  initiateur   Utilisateur @relation("UtilisateurMissionInitiee", fields: [initiateurId], references: [id])

  typeMission TypeMission
  description String
  lieu        String
  dateDebut   DateTime
  dateFin     DateTime

  fraisDeclares Decimal? @db.Decimal(14, 2)
  motifFrais    String?

  statut     StatutMission @default(EN_ATTENTE_RH)
  motifRefus String?

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([employeConcerneId])
  @@index([statut])
}

enum StatutReleveActivite {
  SOUMIS
  VALIDE_RH
}

/// Structure et circuit réels dès ce lot, mais volontairement sans
/// référentiel Projet (projetLibelle reste du texte libre) en attendant le
/// Lot 5 (Direction Technique) — cf. CLAUDE.md.
/// projetId (Lot 5) remplace projetLibelle (texte libre du Lot 4, en
/// attendant que Projet existe réellement) — remplacement net, aucune
/// ligne réelle n'existait à migrer. creerReleveActivite() exige
/// désormais une AffectationProjet active pour (ouvrierId, projetId).
model ReleveActivite {
  id              String               @id @default(cuid())
  ouvrierId       String
  ouvrier         Utilisateur          @relation("UtilisateurReleveOuvrier", fields: [ouvrierId], references: [id])
  projetId        String
  projet          Projet               @relation(fields: [projetId], references: [id])
  periode         String
  joursTravailles Int
  statut          StatutReleveActivite @default(SOUMIS)

  saisiParId String
  saisiPar   Utilisateur @relation("UtilisateurReleveSaisiPar", fields: [saisiParId], references: [id])

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([ouvrierId])
  @@index([statut])
  @@index([projetId])
}

enum StatutAppelOffres {
  EN_ATTENTE_DG
  VALIDE
  REFUSE
}

model DemandeAppelOffres {
  id            String            @id @default(cuid())
  nom           String
  client        String
  montantEstime Decimal           @db.Decimal(14, 2)
  description   String
  delaiReponse  DateTime

  initiateurId String
  initiateur   Utilisateur @relation(fields: [initiateurId], references: [id])

  statut     StatutAppelOffres @default(EN_ATTENTE_DG)
  motifRefus String?

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  piecesJointes PieceJointeAppelOffres[]

  @@index([statut])
  @@index([initiateurId])
}

/// Réutilise le bucket Storage privé "documents" du Lot 2 (préfixe
/// "appel-offres/"), pas une nouvelle infrastructure — cf. CLAUDE.md.
model PieceJointeAppelOffres {
  id                 String             @id @default(cuid())
  demandeId          String
  demande            DemandeAppelOffres @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  cheminFichier      String
  nomFichierOriginal String
}

/// Création directe, pas de circuit de validation. La validation d'un
/// appel d'offres (DemandeAppelOffres) ne crée jamais automatiquement de
/// Projet — les deux sous-modules restent indépendants, cf. CLAUDE.md.
model Projet {
  id           String    @id @default(cuid())
  nom          String
  dateDebut    DateTime
  dateFin      DateTime?
  description  String

  chefProjetId String
  chefProjet   Utilisateur @relation("ProjetChefDeProjet", fields: [chefProjetId], references: [id])

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  pointsValidation PointValidation[]
  affectations     AffectationProjet[]
  demandesRH       DemandeRHProjet[]
  demandesMateriel DemandeMateriel[]
  relevesActivite  ReleveActivite[]

  @@index([chefProjetId])
}

enum StatutPointValidation {
  A_FAIRE
  FAIT
}

model PointValidation {
  id       String @id @default(cuid())
  projetId String
  projet   Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)

  libelle  String
  echeance DateTime
  statut   StatutPointValidation @default(A_FAIRE)

  cochePar       String?
  cocheur        Utilisateur? @relation(fields: [cochePar], references: [id])
  dateValidation DateTime?

  @@index([projetId])
  @@index([statut, echeance])
}

/// Première table de notifications réelle de ce projet — NotificationBell
/// (Lot 0) existait déjà mais n'avait jamais de données (notifications={[]}
/// codé en dur). Alimentée par une vérification "pull" à la navigation
/// (verifierEtCreerAlertesEcheance(), dashboard/layout.tsx), pas par une
/// tâche planifiée — aucune infrastructure cron n'existe dans ce projet.
/// Cf. CLAUDE.md.
model Notification {
  id             String  @id @default(cuid())
  destinataireId String
  destinataire   Utilisateur @relation(fields: [destinataireId], references: [id], onDelete: Cascade)

  titre       String
  description String?
  lu          Boolean @default(false)
  lienDetail  String?

  entiteType String
  entiteId   String

  dateCreation DateTime @default(now())

  @@unique([destinataireId, entiteType, entiteId])
  @@index([destinataireId, lu])
}

enum StatutLigneDemandeRH {
  EN_ATTENTE_RH
  CONTRE_PROPOSEE
  VALIDEE
  REFUSEE
}

model DemandeRHProjet {
  id       String @id @default(cuid())
  projetId String
  projet   Projet @relation(fields: [projetId], references: [id])

  initiateurId String
  initiateur   Utilisateur @relation(fields: [initiateurId], references: [id])

  dateCreation DateTime @default(now())

  lignes LigneDemandeRHProjet[]

  @@index([projetId])
}

/// Circuit par ligne, pas par demande entière — chaque ligne progresse
/// indépendamment (une demande à 3 lignes peut avoir 3 statuts différents
/// simultanément), donc le suivi DemandeIndex/HistoriqueStatut se fait au
/// grain de la ligne (entiteType "LigneDemandeRHProjet"), pas de la
/// demande parente. Cf. CLAUDE.md.
model LigneDemandeRHProjet {
  id        String @id @default(cuid())
  demandeId String
  demande   DemandeRHProjet @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  competence            String
  periode               String
  tauxJournalierPropose Decimal @db.Decimal(14, 2)

  statut     StatutLigneDemandeRH @default(EN_ATTENTE_RH)
  motifRefus String?

  /// Contre-proposition RH (ouvrier + termes alternatifs), en attente de
  /// la décision du DT initiateur de la demande.
  ouvrierContreProposeId      String?
  ouvrierContrePropose        Utilisateur? @relation("LigneOuvrierContrePropose", fields: [ouvrierContreProposeId], references: [id])
  competenceContreProposee    String?
  tauxJournalierContrePropose Decimal? @db.Decimal(14, 2)

  affectation AffectationProjet?

  dateModification DateTime @updatedAt

  @@index([demandeId])
  @@index([statut])
}

/// Créée à la validation finale d'une ligne (directe ou contre-proposition
/// acceptée) — c'est ce que "ajouté au relevé d'activité des ouvriers"
/// signifie concrètement : creerReleveActivite() (Lot 4) exige désormais
/// une affectation active pour le couple (ouvrierId, projetId). Volontairement
/// permanente pour ce lot (pas de statut/dateFin) — cf. CLAUDE.md.
model AffectationProjet {
  id             String  @id @default(cuid())
  projetId       String
  projet         Projet  @relation(fields: [projetId], references: [id])
  ouvrierId      String
  ouvrier        Utilisateur @relation("UtilisateurAffectationOuvrier", fields: [ouvrierId], references: [id])
  competence     String
  tauxJournalier Decimal @db.Decimal(14, 2)

  /// Une affectation naît toujours d'exactement une ligne validée.
  ligneDemandeId String               @unique
  ligneDemande   LigneDemandeRHProjet @relation(fields: [ligneDemandeId], references: [id])

  dateCreation DateTime @default(now())

  @@index([ouvrierId, projetId])
}

/// Référentiel minimal, même esprit que Vehicule (Lot 3) — à étendre par
/// le futur Lot 6 (Logistique), pas remplacer. Cf. CLAUDE.md.
model Materiel {
  id          String  @id @default(cuid())
  designation String
  disponible  Boolean @default(true)

  demandesMateriel DemandeMateriel[]
}

enum StatutDemandeMateriel {
  EN_ATTENTE_LOGISTIQUE
  VALIDEE
  REFUSEE
}

/// Circuit complet qui refuse tant qu'aucune Fonction n'a d'accès
/// Logistique (aucune aujourd'hui) — même politique que les autres cas
/// "refuser si aucun responsable résolu". Cf. CLAUDE.md.
model DemandeMateriel {
  id            String   @id @default(cuid())
  projetId      String?
  projet        Projet?  @relation(fields: [projetId], references: [id])
  chantierLibre String?
  materielId    String
  materiel      Materiel @relation(fields: [materielId], references: [id])
  delaiSouhaite DateTime

  initiateurId String
  initiateur   Utilisateur @relation(fields: [initiateurId], references: [id])

  statut     StatutDemandeMateriel @default(EN_ATTENTE_LOGISTIQUE)
  motifRefus String?

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([projetId])
  @@index([statut])
}

/// Référentiel minimal partagé avec le futur Lot 7 (Achat) — désignation
/// créable par n'importe qui avec accès à liste-articles ; fournisseur/prix
/// restent null et non éditables tant qu'Achat n'existe pas, sur la même
/// table (pas recréée). Distinct de Materiel (4.4) — cf. CLAUDE.md.
model Article {
  id           String   @id @default(cuid())
  designation  String
  fournisseur  String?
  prix         Decimal? @db.Decimal(14, 2)

  creeParId String?
  creePar   Utilisateur? @relation(fields: [creeParId], references: [id])

  dateCreation DateTime @default(now())
}
