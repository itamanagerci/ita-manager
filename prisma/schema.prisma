enum StatutBonSortieTransfert {
  CREE
  ARTICLES_RENSEIGNES
  SIGNE
}

/// Bon de Sortie et Transfert — Matériel/Équipement/Immobilisation (6.12).
/// Distinct du BonSortieMagasin (Livraison A, dépend d'une DMS) : triple
/// signature directe, couvre tout mouvement d'un Materiel existant (pas
/// une consommation de stock via demande). Décrémente le même ledger
/// MouvementStock que le flux-sortie — cf. CLAUDE.md.
model BonSortieTransfert {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  dateSortie            DateTime @default(now())
  lieuSortie            String
  motif                 String
  destination           String
  receptionnaireNom     String
  receptionnaireContact String
  cia                   String?
  demandeTransportId    String?

  demandeurId           String
  demandeur             Utilisateur  @relation("UtilisateurDemandeurBonSortieTransfert", fields: [demandeurId], references: [id])
  expediteurConvoyeurId String?
  expediteurConvoyeur   Utilisateur? @relation("UtilisateurExpediteurBonSortieTransfert", fields: [expediteurConvoyeurId], references: [id])
  dateVisaExpediteur    DateTime?

  /// Cette signature déclenche le décrément de stock — même pattern
  /// atomique interactive que flux-sortie (Livraison A).
  responsableSortieId       String?
  responsableSortie         Utilisateur? @relation("UtilisateurResponsableSortieBonSortieTransfert", fields: [responsableSortieId], references: [id])
  dateVisaResponsableSortie DateTime?

  statut StatutBonSortieTransfert  @default(CREE)
  lignes LigneBonSortieTransfert[]

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt
