// Lot 0 — Socle technique : authentification, rôles, accès, pattern statut/historique.
// Aucun module métier (Achat, QHSE, etc.) n'est modélisé ici — uniquement le référentiel
// de structure (Module/SousModule) et les tables transversales.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — utilisé à l'exécution
  directUrl = env("DIRECT_URL") // connexion directe — utilisée par les migrations
}

enum NiveauHierarchique {
  DIRECTEUR
  CHEF_SERVICE
  AGENT
}

enum StatutUtilisateur {
  ACTIF
  INACTIF
}

/// Référentiel des 9 modules métier + le module transversal "0. Authentification et Rôles".
/// Contient uniquement la structure (noms/slugs) — pas les formulaires/circuits métier.
model Module {
  id          String       @id @default(cuid())
  code        String       @unique
  nom         String
  icone       String?
  ordre       Int          @default(0)
  visibleMenu Boolean      @default(true)
  sousModules SousModule[]
}

/// Chaque Module a toujours au moins un SousModule (y compris les modules "uniques"
/// comme Service Achat, via un sous-module synthétique) — évite les pièges de contrainte
/// d'unicité sur colonnes nullables et uniformise la logique de rendu/garde.
model SousModule {
  id                String                 @id @default(cuid())
  moduleId          String
  module            Module                 @relation(fields: [moduleId], references: [id])
  code              String
  nom               String
  ordre             Int                    @default(0)
  actif             Boolean                @default(true)
  fonctionDefauts   FonctionModuleDefaut[]
  accesUtilisateurs AccesUtilisateur[]

  @@unique([moduleId, code])
}

/// Référentiel des Fonctions (ex: Assistante de direction, Resp. Achat, Chef de chantier...).
/// Détermine les modules/sous-modules accessibles par défaut.
model Fonction {
  id             String                 @id @default(cuid())
  nom            String                 @unique
  description    String?
  actif          Boolean                @default(true)
  utilisateurs   Utilisateur[]
  modulesDefauts FonctionModuleDefaut[]
}

model FonctionModuleDefaut {
  id              String     @id @default(cuid())
  fonctionId      String
  fonction        Fonction   @relation(fields: [fonctionId], references: [id], onDelete: Cascade)
  sousModuleId    String
  sousModule      SousModule @relation(fields: [sousModuleId], references: [id])
  activeParDefaut Boolean    @default(true)

  @@unique([fonctionId, sousModuleId])
}

model Utilisateur {
  id                 String             @id @default(cuid())
  /// UUID Supabase Auth (auth.users.id) — comparaison par valeur uniquement.
  /// Pas de relation Prisma ni de FK gérée par migrate : le schéma auth de
  /// Supabase (sessions, MFA, OAuth...) reste entièrement hors du contrôle
  /// de Prisma pour éviter les faux drifts sur les migrations.
  authUserId         String             @unique @db.Uuid
  nom                String
  prenom             String
  email              String             @unique
  telephone          String?
  /// Lot 8 (DFC) : requis pour être bénéficiaire éligible d'un paiement
  /// mobile money (standard MOBILE_MONEY ou Wave urgent) — vérifié et
  /// refusé sinon, jamais fabriqué. Cf. CLAUDE.md.
  numeroWave         String?
  niveauHierarchique NiveauHierarchique
  fonctionId         String
  fonction           Fonction           @relation(fields: [fonctionId], references: [id])
  statut             StatutUtilisateur  @default(ACTIF)
  premiereConnexion  Boolean            @default(true)
  dateCreation       DateTime           @default(now())
  dateModification   DateTime           @updatedAt

  /// Nullable : les comptes du seed initial n'ont pas de créateur humain.
  /// Pas de onDelete Cascade — supprimer un utilisateur qui a lui-même créé
  /// d'autres comptes est bloqué par possedeDonneesLiees() (gestion-comptes.ts),
  /// même logique que les autres FK non-cascadantes vers Utilisateur.
  creeParId    String?
  creePar      Utilisateur?  @relation("UtilisateurCreateur", fields: [creeParId], references: [id])
  comptesCrees Utilisateur[] @relation("UtilisateurCreateur")

  acces             AccesUtilisateur[] @relation("AccesDuUtilisateur")
  accesModifies     AccesUtilisateur[] @relation("AccesModifiePar")
  actionsHistorique HistoriqueStatut[]

  demandesIndexSoumises DemandeIndex[] @relation("DemandeIndexDemandeur")
  demandesIndexAValider DemandeIndex[] @relation("DemandeIndexValidateur")

  documentsAjoutes Document[] @relation("UtilisateurAjouteDocument")

  demandesCarburantSoumises     DemandeCarburant[]    @relation("UtilisateurDemandeCarburant")
  reapprovisionnementsEffectues Reapprovisionnement[] @relation("UtilisateurReapprovisionnement")

  /// Modèle minimal (un seul niveau, pas d'organigramme complet) — cf.
  /// CLAUDE.md. Pas de onDelete Cascade — supprimer un supérieur désigné
  /// est bloqué par possedeDonneesLiees(), même logique que creeParId.
  superieurId String?
  superieur   Utilisateur?  @relation("UtilisateurSuperieur", fields: [superieurId], references: [id])
  subordonnes Utilisateur[] @relation("UtilisateurSuperieur")

  profilEmploye ProfilEmploye?

  demandesAbsenceSoumises DemandeAbsence[] @relation("UtilisateurDemandeAbsence")
  demandesAbsenceAValider DemandeAbsence[] @relation("UtilisateurValidationAbsence")

  missionsConcernees DemandeMission[] @relation("UtilisateurMissionConcernee")
  missionsInitiees   DemandeMission[] @relation("UtilisateurMissionInitiee")

  relevesActivite ReleveActivite[] @relation("UtilisateurReleveOuvrier")
  relevesSaisis   ReleveActivite[] @relation("UtilisateurReleveSaisiPar")

  appelsOffresInities DemandeAppelOffres[]

  projetsDiriges         Projet[]          @relation("ProjetChefDeProjet")
  pointsValidationCoches PointValidation[]
  notifications          Notification[]

  demandesRHProjetInitiees  DemandeRHProjet[]
  lignesContreProposeesPour LigneDemandeRHProjet[] @relation("LigneOuvrierContrePropose")
  affectationsProjet        AffectationProjet[]    @relation("UtilisateurAffectationOuvrier")

  demandesMaterielInitiees DemandeMateriel[]
  articlesCrees            Article[]

  magasinsResponsable      Magasin[]                 @relation("UtilisateurResponsableMagasin")
  mouvementsStockEffectues MouvementStock[]          @relation("UtilisateurMouvementStock")
  demandesMiseADisposition DemandeMiseADisposition[] @relation("UtilisateurDemandeurDMS")
  verificationsDMS         DemandeMiseADisposition[] @relation("UtilisateurVerificateurDMS")
  decisionsDMS             DemandeMiseADisposition[] @relation("UtilisateurDecideurDMS")
  preparationsBSM          BonSortieMagasin[]        @relation("UtilisateurPreparateurBSM")
  receptionsBSM            BonSortieMagasin[]        @relation("UtilisateurRecepteurBSM")
  receptionsBEM            BonEntreeMagasin[]        @relation("UtilisateurReceptionneurBEM")
  validationsBEM           BonEntreeMagasin[]        @relation("UtilisateurValideurBEM")
  comptagesInventaire      SessionInventaire[]       @relation("UtilisateurCompteurInventaire")
  validationsInventaire    SessionInventaire[]       @relation("UtilisateurValideurInventaire")

  vehiculesConduits               Vehicule[]                    @relation("UtilisateurChauffeurVehicule")
  verificationsInventaireVehicule Vehicule[]                    @relation("UtilisateurVerificateurInventaireVehicule")
  mouvementsVehiculeEffectues     HistoriqueMouvementVehicule[] @relation("UtilisateurMouvementVehicule")
  demandesTransport               DemandeTransport[]            @relation("UtilisateurDemandeurTransport")
  visasLogistiqueTransport        DemandeTransport[]            @relation("UtilisateurVisaLogistiqueTransport")
  gestionsDepartTransport         DemandeTransport[]            @relation("UtilisateurGestionnaireDepartTransport")
  gestionsRetourTransport         DemandeTransport[]            @relation("UtilisateurGestionnaireRetourTransport")
  receptionsInspectionVehicule    InspectionVehicule[]          @relation("UtilisateurReceptionnaireInspVehicule")
  chefChantierInspectionVehicule  InspectionVehicule[]          @relation("UtilisateurChefChantierInspVehicule")
  receptionsInspectionEngin       InspectionEngin[]             @relation("UtilisateurReceptionnaireInspEngin")
  chefChantierInspectionEngin     InspectionEngin[]             @relation("UtilisateurChefChantierInspEngin")
  demandesBonSortieTransfert      BonSortieTransfert[]          @relation("UtilisateurDemandeurBonSortieTransfert")
  expeditionsBonSortieTransfert   BonSortieTransfert[]          @relation("UtilisateurExpediteurBonSortieTransfert")
  responsabiliteSortieTransfert   BonSortieTransfert[]          @relation("UtilisateurResponsableSortieBonSortieTransfert")

  demandesAchatDemandeur     DemandeAchat[]           @relation("UtilisateurDemandeurAchat")
  demandesAchatEmetteur      DemandeAchat[]           @relation("UtilisateurEmetteurAchat")
  demandesAchatCreees        DemandeAchat[]           @relation("UtilisateurCreateurAchat")
  demandesAchatDirecteur     DemandeAchat[]           @relation("UtilisateurDirecteurAchat")
  demandesAchatTraitees      DemandeAchat[]           @relation("UtilisateurTraitantAchat")
  validationsAchatEffectuees ValidationDemandeAchat[]
  bonsCommandeEnvoyes        BonDeCommande[]
  piecesJointesDevisAjoutees PieceJointeDevis[]
  parametresAchatModifies    ParametresAchat[]

  facturesEnregistrees       Facture[]                        @relation("UtilisateurEnregistreFacture")
  paiementsExecutes          Paiement[]                       @relation("UtilisateurExecuteParPaiement")
  demandesCodeUrgent         CodeAutorisationPaiementUrgent[] @relation("UtilisateurDemandeurCodeUrgent")
  validationsCodeUrgent      CodeAutorisationPaiementUrgent[] @relation("UtilisateurValideurCodeUrgent")
  paiementsUrgentsBeneficies PaiementUrgent[]                 @relation("UtilisateurBeneficiairePaiementUrgent")
  paiementsUrgentsExecutes   PaiementUrgent[]                 @relation("UtilisateurExecuteurPaiementUrgent")
}

/// Droits d'accès individuels. Initialisés depuis FonctionModuleDefaut à la création
/// de l'utilisateur ; estException=true marque une exception manuelle RH, exclue de la
/// propagation automatique lors d'une évolution des defaults de la Fonction.
model AccesUtilisateur {
  id               String       @id @default(cuid())
  utilisateurId    String
  utilisateur      Utilisateur  @relation("AccesDuUtilisateur", fields: [utilisateurId], references: [id], onDelete: Cascade)
  sousModuleId     String
  sousModule       SousModule   @relation(fields: [sousModuleId], references: [id])
  actif            Boolean
  estException     Boolean      @default(false)
  modifieParId     String?
  modifiePar       Utilisateur? @relation("AccesModifiePar", fields: [modifieParId], references: [id])
  dateModification DateTime     @updatedAt

  @@unique([utilisateurId, sousModuleId])
}

/// Pattern générique réutilisé par tous les futurs circuits de validation (Achat, Congés,
/// AST...). Discriminant applicatif (entiteType, entiteId) plutôt qu'une relation
/// polymorphe (non supportée par Prisma) — aucune FK vers les tables métier futures.
model HistoriqueStatut {
  id              String      @id @default(cuid())
  entiteType      String
  entiteId        String
  statutPrecedent String?
  statutNouveau   String
  commentaire     String?
  acteurId        String
  acteur          Utilisateur @relation(fields: [acteurId], references: [id])
  dateAction      DateTime    @default(now())

  @@index([entiteType, entiteId])
}

/// Projection d'état courant ("read model") des demandes de n'importe quel
/// module métier futur, agrégée pour la Direction Générale. Complémentaire
/// à HistoriqueStatut (log d'événements immuable) : DemandeIndex ne garde
/// qu'une ligne par entité métier (upsert sur entiteType+entiteId) et
/// reflète toujours le dernier statut connu. Un futur module appelle
/// typiquement les deux à chaque transition : enregistrerTransition() pour
/// l'historique, upsertDemandeIndex() pour la projection DG.
model DemandeIndex {
  id         String  @id @default(cuid())
  typeModule String // code Module d'origine (ex: "achat") — string libre, pas de FK
  sousModule String // code SousModule d'origine — string libre, pas de FK
  reference  String? // identifiant lisible (ex: ACH-2026-00042) — numérotation hors scope

  entiteType String // même discriminant applicatif que HistoriqueStatut
  entiteId   String // @@unique permet l'upsert idempotent à chaque transition

  demandeurId String
  demandeur   Utilisateur @relation("DemandeIndexDemandeur", fields: [demandeurId], references: [id])

  statutLibelle String // libre — chaque module garde son propre enum de statut
  montant       Decimal? @db.Decimal(14, 2)

  /// Convention : une demande est "en attente" si l'un des deux champs
  /// suivants est non-null, "traitée" si les deux sont null.
  /// upsertDemandeIndex() écrase toujours les deux avec la valeur fournie
  /// (jamais de fusion partielle), pour qu'une demande résolue ne reste
  /// jamais affichée comme en attente d'un ancien validateur.
  enAttenteValidationDe            NiveauHierarchique?
  enAttenteValidationUtilisateurId String?
  enAttenteValidationUtilisateur   Utilisateur?        @relation("DemandeIndexValidateur", fields: [enAttenteValidationUtilisateurId], references: [id])

  lienDetail String? // route exacte vers le détail dans le module d'origine, fournie plus tard

  dateSoumission DateTime // date métier réelle, fournie par l'appelant
  dateMaj        DateTime @updatedAt

  @@unique([entiteType, entiteId])
  @@index([typeModule])
  @@index([enAttenteValidationUtilisateurId])
  @@index([enAttenteValidationDe])
  @@index([dateSoumission])
}

enum CategorieDocument {
  CONTRATS
  RH
  JURIDIQUE
  FACTURES
  QHSE
  ACHAT
  TECHNIQUE
  AUTRE
}

/// Lot 2 — Assistant de Direction / Archivage documentaire. Le fichier vit dans le
/// bucket Storage privé "documents" (jamais public — cf. CLAUDE.md) ; cheminFichier
/// est la clé d'objet interne (UUID, pas le nom original), nomFichierOriginal sert
/// uniquement à l'affichage/au téléchargement.
model Document {
  id                 String            @id @default(cuid())
  titre              String
  cheminFichier      String
  nomFichierOriginal String
  categorie          CategorieDocument
  dateAjout          DateTime          @default(now())

  /// Même pattern que Utilisateur.creeParId (Lot 1) : nullable, pas de onDelete
  /// Cascade — supprimer un utilisateur ayant archivé des documents est bloqué
  /// par possedeDonneesLiees() (gestion-comptes.ts).
  ajouteParId String?
  ajoutePar   Utilisateur? @relation("UtilisateurAjouteDocument", fields: [ajouteParId], references: [id])

  @@index([categorie])
}

enum StatutDemandeCarburant {
  EN_ATTENTE_LOGISTIQUE
  EN_ATTENTE_DG
  VALIDEE
  REFUSEE
}

enum TypeVehicule {
  LEGER
  LOURD
  ENGIN
}

/// Statut opérationnel du jour — 3 valeurs réelles observées dans les
/// données de flotte de l'entreprise, pas les 5 valeurs (En service | En
/// réparation | En standby | Réformé | Cédé) du document de cadrage —
/// remplacées volontairement, cf. CLAUDE.md. La sortie définitive
/// (réforme/cession) est une dimension séparée (Vehicule.dateSortieDefinitive),
/// pas une valeur de cet enum.
enum EtatVehicule {
  OK
  PANNE
  HORS_SERVICE
}

/// Lot 3 — minimal (immatriculation, type, quota). Étendu au Lot 6
/// (Livraison B) en vraie fiche véhicule/engin — cf. CLAUDE.md.
model Vehicule {
  id                 String       @id @default(cuid())
  immatriculation    String       @unique
  type               TypeVehicule
  quotaMensuelLitres Int

  numeroInterne   String?
  marque          String?
  modele          String?
  annee           Int?
  dateEntree      DateTime?
  modeAcquisition String?
  etat            EtatVehicule @default(OK)

  chauffeurActuelId String?
  chauffeurActuel   Utilisateur? @relation("UtilisateurChauffeurVehicule", fields: [chauffeurActuelId], references: [id])
  chantierActuel    String?
  compteurActuel    Int?
  dateAffectation   DateTime?

  dateDerniereVerificationInventaire DateTime?
  verificateurDerniereVerificationId String?
  verificateurDerniereVerification   Utilisateur?  @relation("UtilisateurVerificateurInventaireVehicule", fields: [verificateurDerniereVerificationId], references: [id])
  etatConstateDerniereVerification   EtatVehicule?

  /// Dimension distincte de `etat` — cf. CLAUDE.md. Alerte DFC (mise à
  /// jour des immobilisations) non implémentée, Lot 8 pas construit.
  dateSortieDefinitive  DateTime?
  motifSortieDefinitive String?
  valeurResiduelle      Decimal?  @db.Decimal(14, 2)

  demandesCarburant     DemandeCarburant[]
  historiqueMouvements  HistoriqueMouvementVehicule[]
  piecesAdministratives PieceAdministrativeVehicule[]
  demandesTransport     DemandeTransport[]
  inspectionsVehicule   InspectionVehicule[]
  inspectionsEngin      InspectionEngin[]
}

enum TypeMouvementVehicule {
  CHANGEMENT_ETAT
  CHANGEMENT_AFFECTATION
  SORTIE_DEFINITIVE
}

/// Historique des mouvements — table dédiée, même esprit que MouvementStock
/// (Livraison A) : un changement d'affectation a une forme avant/après que
/// HistoriqueStatut générique ne capture pas bien.
model HistoriqueMouvementVehicule {
  id         String                @id @default(cuid())
  vehiculeId String
  vehicule   Vehicule              @relation(fields: [vehiculeId], references: [id])
  type       TypeMouvementVehicule

  etatAvant     EtatVehicule?
  etatApres     EtatVehicule?
  chantierAvant String?
  chantierApres String?
  commentaire   String?

  effectueParId String?
  effectuePar   Utilisateur? @relation("UtilisateurMouvementVehicule", fields: [effectueParId], references: [id])

  date DateTime @default(now())

  @@index([vehiculeId, date])
}

model Depot {
  id                   String                @id @default(cuid())
  nom                  String
  localisation         String
  chantiersRattaches   String[]
  /// Mis à jour par les mouvements (réapprovisionnement, validation finale
  /// d'une demande) — jamais recalculé à la volée à la lecture.
  quantiteStockLitres  Int                   @default(0)
  demandesCarburant    DemandeCarburant[]
  reapprovisionnements Reapprovisionnement[]
}

/// Pas de circuit de validation — saisie directe par le Responsable
/// Logistique/Carburant, incrémente Depot.quantiteStockLitres à la création.
model Reapprovisionnement {
  id             String   @id @default(cuid())
  depotId        String
  depot          Depot    @relation(fields: [depotId], references: [id])
  quantiteLitres Int
  date           DateTime @default(now())
  fournisseur    String

  /// Même pattern non-cascadant que Utilisateur.creeParId/Document.ajouteParId.
  effectueParId String?
  effectuePar   Utilisateur? @relation("UtilisateurReapprovisionnement", fields: [effectueParId], references: [id])
}

model DemandeCarburant {
  id                     String                 @id @default(cuid())
  vehiculeId             String
  vehicule               Vehicule               @relation(fields: [vehiculeId], references: [id])
  depotSourceId          String
  depotSource            Depot                  @relation(fields: [depotSourceId], references: [id])
  kilometrageCompteur    Int
  quantiteDemandeeLitres Int
  chantierMission        String
  demandeurId            String
  demandeur              Utilisateur            @relation("UtilisateurDemandeCarburant", fields: [demandeurId], references: [id])
  statut                 StatutDemandeCarburant @default(EN_ATTENTE_LOGISTIQUE)
  motifRefus             String?

  /// Cumul mensuel du véhicule AVANT cette demande, figé à la création (sert
  /// à déterminer le hors-quota) — jamais recalculé ensuite. Cf. CLAUDE.md.
  cumulMensuelAvant Int

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([vehiculeId, statut])
  @@index([statut])
  @@index([demandeurId])
}

enum TypeProfilEmploye {
  AGENT
  SOUS_TRAITANT
  OUVRIER
}

/// Lot 4 — DARH. Relation 1:1 OPTIONNELLE avec Utilisateur (onDelete: Cascade
/// — appartient entièrement au compte, même logique que AccesUtilisateur,
/// pas un enregistrement d'audit sur l'action de quelqu'un d'autre) : un
/// compte peut exister sans profil RH complété.
model ProfilEmploye {
  id            String            @id @default(cuid())
  utilisateurId String            @unique
  utilisateur   Utilisateur       @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  typeProfil    TypeProfilEmploye
  poste         String
  service       String
  dateEntree    DateTime
  soldeConges   Int               @default(0)

  salaireFixe         Decimal? @db.Decimal(14, 2)
  entrepriseRattachee String?
  tauxJournalier      Decimal? @db.Decimal(14, 2)
}

enum TypeAbsence {
  CONGE
  PERMISSION
}

enum StatutAbsence {
  EN_ATTENTE_SUPERIEUR
  VALIDEE
  REFUSEE
}

model DemandeAbsence {
  id                 String        @id @default(cuid())
  employeId          String
  employe            Utilisateur   @relation("UtilisateurDemandeAbsence", fields: [employeId], references: [id])
  type               TypeAbsence
  dateDebut          DateTime
  dateFin            DateTime? // requis si CONGE
  dureeHeures        Int? // requis si PERMISSION
  motif              String
  statut             StatutAbsence @default(EN_ATTENTE_SUPERIEUR)
  motifRefus         String?
  impacteSoldeConges Boolean // dérivé du type à la création, jamais un input utilisateur

  /// Figé depuis employe.superieurId à la création — routage stable même si
  /// le supérieur de l'employé change ensuite. Cf. CLAUDE.md.
  superieurId String
  superieur   Utilisateur @relation("UtilisateurValidationAbsence", fields: [superieurId], references: [id])

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([employeId])
  @@index([superieurId, statut])
}

enum TypeMission {
  CHANTIER
  FORMATION
  REPRESENTATION_CLIENT
  AUTRE
}

enum StatutMission {
  EN_ATTENTE_RH
  VALIDEE_RH
  REFUSEE
}

/// Se termine à VALIDEE_RH pour ce lot — le futur Lot 8 (DFC) reprendra les
/// missions à ce statut pour l'étape de paiement. Cf. CLAUDE.md.
model DemandeMission {
  id                String      @id @default(cuid())
  employeConcerneId String
  employeConcerne   Utilisateur @relation("UtilisateurMissionConcernee", fields: [employeConcerneId], references: [id])

  /// Peut différer de employeConcerneId (un supérieur soumet pour son équipe).
  initiateurId String
  initiateur   Utilisateur @relation("UtilisateurMissionInitiee", fields: [initiateurId], references: [id])

  typeMission TypeMission
  description String
  lieu        String
  dateDebut   DateTime
  dateFin     DateTime

  fraisDeclares Decimal? @db.Decimal(14, 2)
  motifFrais    String?

  statut     StatutMission @default(EN_ATTENTE_RH)
  motifRefus String?

  dateCreation     DateTime  @default(now())
  dateModification DateTime  @updatedAt
  paiement         Paiement?

  @@index([employeConcerneId])
  @@index([statut])
}

enum StatutReleveActivite {
  SOUMIS
  VALIDE_RH
}

/// Structure et circuit réels dès ce lot, mais volontairement sans
/// référentiel Projet (projetLibelle reste du texte libre) en attendant le
/// Lot 5 (Direction Technique) — cf. CLAUDE.md.
/// projetId (Lot 5) remplace projetLibelle (texte libre du Lot 4, en
/// attendant que Projet existe réellement) — remplacement net, aucune
/// ligne réelle n'existait à migrer. creerReleveActivite() exige
/// désormais une AffectationProjet active pour (ouvrierId, projetId).
model ReleveActivite {
  id              String               @id @default(cuid())
  ouvrierId       String
  ouvrier         Utilisateur          @relation("UtilisateurReleveOuvrier", fields: [ouvrierId], references: [id])
  projetId        String
  projet          Projet               @relation(fields: [projetId], references: [id])
  periode         String
  joursTravailles Int
  statut          StatutReleveActivite @default(SOUMIS)

  saisiParId String
  saisiPar   Utilisateur @relation("UtilisateurReleveSaisiPar", fields: [saisiParId], references: [id])

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([ouvrierId])
  @@index([statut])
  @@index([projetId])
}

enum StatutAppelOffres {
  EN_ATTENTE_DG
  VALIDE
  REFUSE
}

model DemandeAppelOffres {
  id            String   @id @default(cuid())
  nom           String
  client        String
  montantEstime Decimal  @db.Decimal(14, 2)
  description   String
  delaiReponse  DateTime

  initiateurId String
  initiateur   Utilisateur @relation(fields: [initiateurId], references: [id])

  statut     StatutAppelOffres @default(EN_ATTENTE_DG)
  motifRefus String?

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  piecesJointes PieceJointeAppelOffres[]

  @@index([statut])
  @@index([initiateurId])
}

/// Réutilise le bucket Storage privé "documents" du Lot 2 (préfixe
/// "appel-offres/"), pas une nouvelle infrastructure — cf. CLAUDE.md.
model PieceJointeAppelOffres {
  id                 String             @id @default(cuid())
  demandeId          String
  demande            DemandeAppelOffres @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  cheminFichier      String
  nomFichierOriginal String
}

/// Création directe, pas de circuit de validation. La validation d'un
/// appel d'offres (DemandeAppelOffres) ne crée jamais automatiquement de
/// Projet — les deux sous-modules restent indépendants, cf. CLAUDE.md.
model Projet {
  id          String    @id @default(cuid())
  nom         String
  dateDebut   DateTime
  dateFin     DateTime?
  description String

  chefProjetId String
  chefProjet   Utilisateur @relation("ProjetChefDeProjet", fields: [chefProjetId], references: [id])

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  pointsValidation PointValidation[]
  affectations     AffectationProjet[]
  demandesRH       DemandeRHProjet[]
  demandesMateriel DemandeMateriel[]
  relevesActivite  ReleveActivite[]

  /// Lot 7 (Achat) : deux relations distinctes, jamais confondues — une
  /// demande peut concerner un chantier (forType=CHANTIER, projetId) tout
  /// en étant livrée sur un AUTRE chantier (lieuLivraisonProjetId). Cf.
  /// CLAUDE.md.
  demandesAchatChantier  DemandeAchat[] @relation("DemandeAchatChantier")
  demandesAchatLivraison DemandeAchat[] @relation("DemandeAchatLieuLivraison")

  @@index([chefProjetId])
}

enum StatutPointValidation {
  A_FAIRE
  FAIT
}

model PointValidation {
  id       String @id @default(cuid())
  projetId String
  projet   Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)

  libelle  String
  echeance DateTime
  statut   StatutPointValidation @default(A_FAIRE)

  cochePar       String?
  cocheur        Utilisateur? @relation(fields: [cochePar], references: [id])
  dateValidation DateTime?

  @@index([projetId])
  @@index([statut, echeance])
}

/// Première table de notifications réelle de ce projet — NotificationBell
/// (Lot 0) existait déjà mais n'avait jamais de données (notifications={[]}
/// codé en dur). Alimentée par une vérification "pull" à la navigation
/// (verifierEtCreerAlertesEcheance(), dashboard/layout.tsx), pas par une
/// tâche planifiée — aucune infrastructure cron n'existe dans ce projet.
/// Cf. CLAUDE.md.
model Notification {
  id             String      @id @default(cuid())
  destinataireId String
  destinataire   Utilisateur @relation(fields: [destinataireId], references: [id], onDelete: Cascade)

  titre       String
  description String?
  lu          Boolean @default(false)
  lienDetail  String?

  entiteType String
  entiteId   String

  dateCreation DateTime @default(now())

  @@unique([destinataireId, entiteType, entiteId])
  @@index([destinataireId, lu])
}

enum StatutLigneDemandeRH {
  EN_ATTENTE_RH
  CONTRE_PROPOSEE
  VALIDEE
  REFUSEE
}

model DemandeRHProjet {
  id       String @id @default(cuid())
  projetId String
  projet   Projet @relation(fields: [projetId], references: [id])

  initiateurId String
  initiateur   Utilisateur @relation(fields: [initiateurId], references: [id])

  dateCreation DateTime @default(now())

  lignes LigneDemandeRHProjet[]

  @@index([projetId])
}

/// Circuit par ligne, pas par demande entière — chaque ligne progresse
/// indépendamment (une demande à 3 lignes peut avoir 3 statuts différents
/// simultanément), donc le suivi DemandeIndex/HistoriqueStatut se fait au
/// grain de la ligne (entiteType "LigneDemandeRHProjet"), pas de la
/// demande parente. Cf. CLAUDE.md.
model LigneDemandeRHProjet {
  id        String          @id @default(cuid())
  demandeId String
  demande   DemandeRHProjet @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  competence            String
  periode               String
  tauxJournalierPropose Decimal @db.Decimal(14, 2)

  statut     StatutLigneDemandeRH @default(EN_ATTENTE_RH)
  motifRefus String?

  /// Contre-proposition RH (ouvrier + termes alternatifs), en attente de
  /// la décision du DT initiateur de la demande.
  ouvrierContreProposeId      String?
  ouvrierContrePropose        Utilisateur? @relation("LigneOuvrierContrePropose", fields: [ouvrierContreProposeId], references: [id])
  competenceContreProposee    String?
  tauxJournalierContrePropose Decimal?     @db.Decimal(14, 2)

  affectation AffectationProjet?

  dateModification DateTime @updatedAt

  @@index([demandeId])
  @@index([statut])
}

/// Créée à la validation finale d'une ligne (directe ou contre-proposition
/// acceptée) — c'est ce que "ajouté au relevé d'activité des ouvriers"
/// signifie concrètement : creerReleveActivite() (Lot 4) exige désormais
/// une affectation active pour le couple (ouvrierId, projetId). Volontairement
/// permanente pour ce lot (pas de statut/dateFin) — cf. CLAUDE.md.
model AffectationProjet {
  id             String      @id @default(cuid())
  projetId       String
  projet         Projet      @relation(fields: [projetId], references: [id])
  ouvrierId      String
  ouvrier        Utilisateur @relation("UtilisateurAffectationOuvrier", fields: [ouvrierId], references: [id])
  competence     String
  tauxJournalier Decimal     @db.Decimal(14, 2)

  /// Une affectation naît toujours d'exactement une ligne validée.
  ligneDemandeId String               @unique
  ligneDemande   LigneDemandeRHProjet @relation(fields: [ligneDemandeId], references: [id])

  dateCreation DateTime @default(now())

  @@index([ouvrierId, projetId])
}

/// Référentiel initialement minimal (Lot 5), étendu au Lot 6 (Livraison A)
/// en vraie fiche article de magasin. Champs de fiche-inventaire tous
/// nullable : le seed historique "Bétonnière 350L" (gros équipement
/// empruntable hors circuit de stock) les garde à null indéfiniment ; seuls
/// les articles créés via fiche-inventaire les renseignent. Cf. CLAUDE.md.
model Materiel {
  id          String  @id @default(cuid())
  designation String
  disponible  Boolean @default(true)

  reference           String?            @unique
  categorieId         String?
  categorie           CategorieMateriel? @relation(fields: [categorieId], references: [id])
  uniteMesureId       String?
  uniteMesure         UniteMesure?       @relation(fields: [uniteMesureId], references: [id])
  magasinId           String?
  magasin             Magasin?           @relation(fields: [magasinId], references: [id])
  emplacement         String?
  fournisseurHabituel String?

  /// Solde persistant, jamais recalculé à la lecture — même pattern que
  /// Depot.quantiteStockLitres (Lot 3). Modifié UNIQUEMENT via les
  /// mouvements (entrée/sortie/ajustement), jamais un update générique.
  quantiteStock              Int?
  dateCreationStock          DateTime?
  seuilAlerte                Int?
  /// Recommandé = seuilAlerte ÷ 2 — champ explicite saisi, jamais calculé.
  stockSecurite              Int?
  quantiteReapproStandard    Int?
  delaiFournisseurMoyenJours Int?

  dateModification DateTime @updatedAt

  demandesMateriel            DemandeMateriel[]
  mouvementsStock             MouvementStock[]
  lignesInventaire            LigneInventaire[]
  demandesReapprovisionnement DemandeReapprovisionnement[]
  lignesDMS                   LigneDemandeMiseADisposition[]
  lignesBEM                   LigneBonEntreeMagasin[]
  lignesBonSortieTransfert    LigneBonSortieTransfert[]

  @@index([categorieId])
  @@index([magasinId])
}

enum StatutDemandeMateriel {
  EN_ATTENTE_LOGISTIQUE
  VALIDEE
  REFUSEE
}

/// Débloqué au Lot 6 (Livraison A) : une vraie Fonction "Responsable
/// Service Logistique" a désormais accès à logistique/magasins, donc
/// resoudreResponsableLogistiqueMateriel() résout un responsable réel.
/// Zéro changement de code ici — uniquement un changement de seed. Cf.
/// CLAUDE.md.
model DemandeMateriel {
  id            String   @id @default(cuid())
  projetId      String?
  projet        Projet?  @relation(fields: [projetId], references: [id])
  chantierLibre String?
  materielId    String
  materiel      Materiel @relation(fields: [materielId], references: [id])
  delaiSouhaite DateTime

  initiateurId String
  initiateur   Utilisateur @relation(fields: [initiateurId], references: [id])

  statut     StatutDemandeMateriel @default(EN_ATTENTE_LOGISTIQUE)
  motifRefus String?

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([projetId])
  @@index([statut])
}

/// Référentiel minimal partagé avec le futur Lot 7 (Achat) — désignation
/// créable par n'importe qui avec accès à liste-articles ; fournisseur/prix
/// restent null et non éditables tant qu'Achat n'existe pas, sur la même
/// table (pas recréée). Distinct de Materiel (4.4) — cf. CLAUDE.md.
model Article {
  id          String   @id @default(cuid())
  designation String
  fournisseur String?
  prix        Decimal? @db.Decimal(14, 2)

  creeParId String?
  creePar   Utilisateur? @relation(fields: [creeParId], references: [id])

  dateCreation DateTime @default(now())

  /// Lot 7 (Achat) : deuxième chemin d'écriture indépendant vers
  /// fournisseur/prix, via mettreAJourArticleFournisseurPrix() — jamais via
  /// creerArticle() (Lot 5, direction-technique/liste-articles), qui ne
  /// renseigne jamais que designation/creeParId. Cf. CLAUDE.md.
  lignesDemandeAchat LigneDemandeAchat[]
}

// ─────────────────────────────────────────────────────────────────────────
// Lot 6 — Service Logistique, Livraison A (stock). Contenu fidèle au
// document officiel "Workflow_Gestion_Inventaires_ITA" fourni par
// l'utilisateur — 4 magasins réels, 6 catégories réelles, 6 unités de
// mesure réelles, champs exacts des formulaires DMS/BSM/BEM/FIC. Cf.
// CLAUDE.md pour le raisonnement complet (Chef Magasin nommé par magasin,
// DemandeReapprovisionnement jamais wired à DemandeIndex, etc.).
// ─────────────────────────────────────────────────────────────────────────

model Magasin {
  id            String       @id @default(cuid())
  code          String       @unique
  nom           String
  /// Chef Magasin nommé — autorise seul l'étape "vérification stock" d'une
  /// DMS pour CE magasin (même pattern que DemandeAbsence.superieurId : la
  /// cible du routage EST l'autorisation, pas un accès sous-module). Pas de
  /// onDelete Cascade — supprimer un Chef Magasin assigné est bloqué par
  /// possedeDonneesLiees(), même logique que creeParId/superieurId.
  responsableId String?
  responsable   Utilisateur? @relation("UtilisateurResponsableMagasin", fields: [responsableId], references: [id])

  materiels                Materiel[]
  demandesMiseADisposition DemandeMiseADisposition[]
  bonsSortieMagasin        BonSortieMagasin[]
  bonsEntreeMagasin        BonEntreeMagasin[]
  sessionsInventaire       SessionInventaire[]
}

/// Table plutôt qu'enum (même raisonnement que Module/SousModule) :
/// éditable sans migration Prisma. 6 valeurs réelles (pas 8, une ébauche
/// provisoire sans document réel en avait inventé 8) — Véhicules/Engins en
/// sont volontairement exclus, suivis séparément via Vehicule (Livraison B).
model CategorieMateriel {
  id        String     @id @default(cuid())
  code      String     @unique
  nom       String
  ordre     Int        @default(0)
  actif     Boolean    @default(true)
  materiels Materiel[]
}

/// Table plutôt qu'enum, même raisonnement que CategorieMateriel. 6 valeurs
/// réelles.
model UniteMesure {
  id        String     @id @default(cuid())
  code      String     @unique
  nom       String
  ordre     Int        @default(0)
  actif     Boolean    @default(true)
  materiels Materiel[]
}

enum TypeMouvementStock {
  ENTREE
  SORTIE
  AJUSTEMENT
}

/// Journal unique pour flux-entree/flux-sortie/inventaire-periodique —
/// même grain, seul le sens diffère. Créé automatiquement par la
/// validation d'un BSM (SORTIE), d'un BEM (ENTREE) ou la clôture d'une
/// session d'inventaire (AJUSTEMENT), jamais directement par un
/// formulaire. Cf. CLAUDE.md pour le pattern atomique repris de
/// carburant.ts (Lot 3).
model MouvementStock {
  id                     String             @id @default(cuid())
  materielId             String
  materiel               Materiel           @relation(fields: [materielId], references: [id])
  type                   TypeMouvementStock
  quantite               Int
  quantiteApresMouvement Int
  motif                  String?

  effectueParId String?
  effectuePar   Utilisateur? @relation("UtilisateurMouvementStock", fields: [effectueParId], references: [id])

  date DateTime @default(now())

  @@index([materielId, date])
  @@index([type])
}

enum UrgenceDMS {
  NORMAL
  URGENT
}

enum StatutVerificationStock {
  DISPONIBLE
  RUPTURE_PARTIELLE
  RUPTURE_TOTALE
}

enum DecisionLogisticien {
  APPROUVEE
  TRANSFERT_INTER_MAGASIN
  DEMANDE_ACHAT_DECLENCHEE
  REFUSEE
}

enum StatutDMS {
  EN_ATTENTE_VERIFICATION
  EN_ATTENTE_DECISION
  APPROUVEE
  TRANSFERT_INTER_MAGASIN
  DEMANDE_ACHAT_DECLENCHEE
  REFUSEE
}

/// Demande de Mise à Disposition Stock (flux-sortie) — circuit à 2 acteurs
/// nommés : Chef Magasin (magasin.responsableId) vérifie la disponibilité,
/// puis Logisticien (accès logistique/magasins) décide. Refuse la création
/// si le magasin visé n'a pas de responsable désigné — même règle "refuser
/// plutôt que fabriquer un routage" que le congé (Lot 4). Cf. CLAUDE.md.
model DemandeMiseADisposition {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  magasinId       String
  magasin         Magasin @relation(fields: [magasinId], references: [id])
  chantierService String

  urgence              UrgenceDMS @default(NORMAL)
  justificationUrgence String?

  demandeurId        String
  demandeur          Utilisateur @relation("UtilisateurDemandeurDMS", fields: [demandeurId], references: [id])
  demandeurPoste     String
  demandeurTelephone String

  statut StatutDMS @default(EN_ATTENTE_VERIFICATION)

  verificationStatut       StatutVerificationStock?
  verificationObservations String?
  verifieParId             String?
  verifiePar               Utilisateur?             @relation("UtilisateurVerificateurDMS", fields: [verifieParId], references: [id])
  dateVerification         DateTime?

  decision     DecisionLogisticien?
  motifRefus   String?
  decideParId  String?
  decidePar    Utilisateur?         @relation("UtilisateurDecideurDMS", fields: [decideParId], references: [id])
  dateDecision DateTime?

  /// Renseigné si decision = DEMANDE_ACHAT_DECLENCHEE — lien vers la
  /// DemandeReapprovisionnement créée/réutilisée à cette occasion.
  demandeReapprovisionnementId String?

  lignes    LigneDemandeMiseADisposition[]
  bonSortie BonSortieMagasin?

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([magasinId, statut])
  @@index([statut])
}

model LigneDemandeMiseADisposition {
  id               String                  @id @default(cuid())
  demandeId        String
  demande          DemandeMiseADisposition @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  materielId       String
  materiel         Materiel                @relation(fields: [materielId], references: [id])
  quantiteDemandee Int
}

enum StatutBonSortie {
  EMIS
  RECU
}

/// Émis par deciderDMS() quand decision = APPROUVEE. Le stock est
/// décrémenté à ce moment (pattern atomique interactive, cf. CLAUDE.md),
/// pas à la création de la DMS.
model BonSortieMagasin {
  id        String                  @id @default(cuid())
  numero    Int                     @unique @default(autoincrement())
  demandeId String                  @unique
  demande   DemandeMiseADisposition @relation(fields: [demandeId], references: [id])

  magasinId            String
  magasin              Magasin @relation(fields: [magasinId], references: [id])
  destinataireChantier String

  statut StatutBonSortie @default(EMIS)

  /// Attribué automatiquement au Chef Magasin qui a vérifié la DMS — pas
  /// une action séparée, la préparation physique suit la vérification.
  preparateurId String?
  preparateur   Utilisateur? @relation("UtilisateurPreparateurBSM", fields: [preparateurId], references: [id])
  dateEmission  DateTime     @default(now())

  recuParId     String?
  recuPar       Utilisateur? @relation("UtilisateurRecepteurBSM", fields: [recuParId], references: [id])
  dateReception DateTime?

  @@index([statut])
}

enum ConformiteBEM {
  CONFORME
  NON_CONFORME_AVEC_RESERVES
}

enum ActionEcartBEM {
  RETOUR_FOURNISSEUR
  AVOIR_A_RECEVOIR
  REGULARISATION_ADMIN
  ACCEPTE_AVEC_RESERVE
}

enum StatutBEM {
  EN_ATTENTE_VALIDATION
  VALIDE
}

/// Bon d'Entrée Magasin (flux-entree) — Chef Magasin réceptionne et
/// enregistre (auto-attribué, pas de routage nommé : ce n'est pas une
/// demande adressée à quelqu'un), puis le Logisticien (accès
/// logistique/magasins) valide. C'est la validation, pas la création, qui
/// met à jour la fiche inventaire — conforme au document. Cf. CLAUDE.md.
model BonEntreeMagasin {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  demandeReapprovisionnementId String?
  demandeReapprovisionnement   DemandeReapprovisionnement? @relation(fields: [demandeReapprovisionnementId], references: [id])

  /// Lot 7 (Achat) : trace optionnelle vers le Bon de Commande à l'origine
  /// de cette livraison — même forme/nullabilité que
  /// demandeReapprovisionnementId ci-dessus, aucun autre changement au
  /// circuit BEM du Lot 6. Cf. CLAUDE.md.
  bonDeCommandeId String?
  bonDeCommande   BonDeCommande? @relation(fields: [bonDeCommandeId], references: [id])

  bonLivraisonFournisseurNumero String
  dateReception                 DateTime
  magasinId                     String
  magasin                       Magasin  @relation(fields: [magasinId], references: [id])
  fournisseur                   String

  conformite  ConformiteBEM?
  reserves    String?
  actionEcart ActionEcartBEM?

  statut StatutBEM @default(EN_ATTENTE_VALIDATION)

  receptionneParId String?
  receptionnePar   Utilisateur? @relation("UtilisateurReceptionneurBEM", fields: [receptionneParId], references: [id])

  valideParId    String?
  validePar      Utilisateur? @relation("UtilisateurValideurBEM", fields: [valideParId], references: [id])
  dateValidation DateTime?

  lignes LigneBonEntreeMagasin[]

  dateCreation DateTime @default(now())

  @@index([magasinId, statut])
  @@index([statut])
}

model LigneBonEntreeMagasin {
  id            String           @id @default(cuid())
  bemId         String
  bem           BonEntreeMagasin @relation(fields: [bemId], references: [id], onDelete: Cascade)
  materielId    String
  materiel      Materiel         @relation(fields: [materielId], references: [id])
  quantiteRecue Int
}

enum TypeInventaire {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
  EXCEPTIONNEL
}

enum StatutSessionInventaire {
  EN_COURS
  CLOTUREE
}

/// Fiche de Comptage (inventaire-periodique). cloturerSessionInventaire()
/// applique chaque écart en SET direct (quantiteStock = quantitePhysique),
/// pas un increment/decrement — une correction vers une vérité
/// physiquement constatée, pas une opération concurrente à protéger comme
/// une sortie. Cf. CLAUDE.md pour la simplification de concurrence assumée.
model SessionInventaire {
  id             String                  @id @default(cuid())
  numero         Int                     @unique @default(autoincrement())
  type           TypeInventaire
  magasinId      String
  magasin        Magasin                 @relation(fields: [magasinId], references: [id])
  equipeComptage String?
  statut         StatutSessionInventaire @default(EN_COURS)

  effectueParId String?
  effectuePar   Utilisateur? @relation("UtilisateurCompteurInventaire", fields: [effectueParId], references: [id])

  valideParId    String?
  validePar      Utilisateur? @relation("UtilisateurValideurInventaire", fields: [valideParId], references: [id])
  dateValidation DateTime?

  lignes LigneInventaire[]

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([statut])
  @@index([magasinId])
}

/// Appartient entièrement à sa session (comme PointValidation à Projet) —
/// cascade correcte, pas un enregistrement d'audit d'une tierce action.
model LigneInventaire {
  id                String            @id @default(cuid())
  sessionId         String
  session           SessionInventaire @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  materielId        String
  materiel          Materiel          @relation(fields: [materielId], references: [id])
  quantiteTheorique Int
  quantitePhysique  Int
  ecart             Int
  commentaire       String?

  @@unique([sessionId, materielId])
}

enum StatutDemandeReapprovisionnement {
  EN_ATTENTE_ACHAT
}

/// Créée automatiquement (détection passive au chargement de la page
/// seuil-alerte, OU décision DMS "Demande d'achat déclenchée") — jamais
/// par un humain directement. Suivie via enregistrerTransition() pour
/// l'audit, mais DÉLIBÉRÉMENT jamais wired à upsertDemandeIndex() : aucune
/// cible de routage réelle n'existe tant que le Lot 7 (Achat) n'existe pas
/// — l'écrire avec les deux champs de validation à null la ferait lire
/// comme "traitée", le piège que CLAUDE.md interdit explicitement. Un seul
/// statut pour ce lot ; Lot 7 étendra le cycle de vie via sa propre
/// migration. Cf. CLAUDE.md.
model DemandeReapprovisionnement {
  id         String                           @id @default(cuid())
  materielId String
  materiel   Materiel                         @relation(fields: [materielId], references: [id])
  statut     StatutDemandeReapprovisionnement @default(EN_ATTENTE_ACHAT)

  quantiteStockConstatee Int
  seuilAlerteConstate    Int

  dateCreation DateTime @default(now())

  bonsEntreeMagasin BonEntreeMagasin[]

  @@unique([materielId, statut])
  @@index([statut])
}

// ─────────────────────────────────────────────────────────────────────────
// Lot 6 — Service Logistique, Livraison B (véhicules, engins, transport).
// Contenu fidèle aux sections 6.7–6.14 du document de cadrage original —
// cf. CLAUDE.md pour le raisonnement complet (rôles réutilisés de la
// Livraison A, contenu placeholder signalé pour les points d'inspection
// non énumérés dans le document, etc.).
// ─────────────────────────────────────────────────────────────────────────

/// Table plutôt qu'enum, même raisonnement que CategorieMateriel/UniteMesure
/// (Livraison A). Contenu réel tiré des fichiers Excel "Contrôle
/// réglementaire" fournis par l'utilisateur.
model TypePieceAdministrative {
  id              String  @id @default(cuid())
  code            String  @unique
  nom             String
  /// Null pour les pièces non-récurrentes (ex. Carte Grise).
  periodiciteMois Int?
  ordre           Int     @default(0)
  actif           Boolean @default(true)

  pieces PieceAdministrativeVehicule[]
}

/// Suivi documentaire par véhicule (6.8) — pas de circuit de validation,
/// gestion directe. Alerte d'expiration : cf. verifierEtCreerAlertesExpirationPieces()
/// (pieces-admin-vehicules.ts), pattern page-level comme seuil-alerte.
model PieceAdministrativeVehicule {
  id          String                  @id @default(cuid())
  vehiculeId  String
  vehicule    Vehicule                @relation(fields: [vehiculeId], references: [id])
  typePieceId String
  typePiece   TypePieceAdministrative @relation(fields: [typePieceId], references: [id])

  dateEmission   DateTime?
  dateExpiration DateTime?

  /// Bucket Storage privé "documents" (Lot 2), préfixe "pieces-admin-vehicules/".
  cheminFichier      String?
  nomFichierOriginal String?

  dateCreation DateTime @default(now())

  @@index([vehiculeId])
  @@index([dateExpiration])
}

enum NatureDemandeTransport {
  TRANSPORT_TRANSFERT
  MISE_A_DISPOSITION
}

enum StatutDemandeTransport {
  SOUMIS
  VISA_LOGISTIQUE
  VERIFIE_DEPART
  EN_COURS
  VERIFIE_RETOUR
  ARCHIVE
  REFUSE
}

/// Circuit à 5 étapes (6.10) — Demandeur → visa Logistique + affectation
/// véhicule → checklist/visa Départ (Chef Magasin, rôle "Section
/// Transport/Garage") → checklist/visa Retour → archivé. Aucune nouvelle
/// Fonction : réutilise Responsable Service Logistique et Chef Magasin de
/// la Livraison A. Cf. CLAUDE.md.
model DemandeTransport {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  serviceChantier String
  /// Centre d'Imputation Analytique.
  cia             String
  nature          NatureDemandeTransport
  description     String
  dateDebut       DateTime
  dateFin         DateTime

  demandeurId String
  demandeur   Utilisateur @relation("UtilisateurDemandeurTransport", fields: [demandeurId], references: [id])

  statut StatutDemandeTransport @default(SOUMIS)

  vehiculeId          String?
  vehicule            Vehicule?    @relation(fields: [vehiculeId], references: [id])
  visaLogistiqueParId String?
  visaLogistiquePar   Utilisateur? @relation("UtilisateurVisaLogistiqueTransport", fields: [visaLogistiqueParId], references: [id])
  dateVisaLogistique  DateTime?

  conducteurDepartNom  String?
  compteurDepart       Int?
  dateDepartReelle     DateTime?
  gestionnaireDepartId String?
  gestionnaireDepart   Utilisateur? @relation("UtilisateurGestionnaireDepartTransport", fields: [gestionnaireDepartId], references: [id])

  conducteurRetourNom  String?
  compteurRetour       Int?
  dateRetourReelle     DateTime?
  gestionnaireRetourId String?
  gestionnaireRetour   Utilisateur? @relation("UtilisateurGestionnaireRetourTransport", fields: [gestionnaireRetourId], references: [id])
  /// "Référence ITA" — visa retour, cas engin.
  referenceEngin       String?

  motifRefus String?

  reponsesChecklist ReponseChecklistTransport[]

  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt

  @@index([statut])
}

enum CategorieItemChecklistTransport {
  MATERIEL_BORD
  PIECE_ADMINISTRATIVE
  DOCUMENT_SUIVI
}

/// Référentiel fixe (table, pas enum) — 9 matériels à bord + 6 pièces
/// administratives + 1 document de suivi, contenu réel du document.
model ItemChecklistTransport {
  id        String                          @id @default(cuid())
  categorie CategorieItemChecklistTransport
  code      String                          @unique
  libelle   String
  ordre     Int                             @default(0)
  actif     Boolean                         @default(true)

  reponses ReponseChecklistTransport[]
}

/// Une ligne par item, colonnes Départ/Retour sur la même ligne plutôt que
/// deux lignes distinctes — évite une jointure pour afficher le tableau D/R.
model ReponseChecklistTransport {
  id        String                 @id @default(cuid())
  demandeId String
  demande   DemandeTransport       @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  itemId    String
  item      ItemChecklistTransport @relation(fields: [itemId], references: [id])

  presentDepart Boolean?
  presentRetour Boolean?

  @@unique([demandeId, itemId])
